# KubeVirt virt-launcher Image
# Author: Punith Kenchappa <pkenchap@in.ibm.com>
# Architecture: ppc64le

FROM quay.io/fedora/fedora:42-ppc64le AS build

# Install runtime dependencies for virt-launcher (matching launcherbase from rpm/BUILD.bazel)
